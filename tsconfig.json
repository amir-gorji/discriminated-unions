{
  "compilerOptions": {
    "target": "es2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "src/playground.ts"]
}
